      "source": [
        "# Veri Temizliği(NLP Preprocessing)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "V0HbsjElou3c",
        "outputId": "bb30e8b9-9add-4ec8-ef1e-a9c763a92839"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stderr",
          "text": [
            "[nltk_data] Downloading package stopwords to /root/nltk_data...\n",
            "[nltk_data]   Unzipping corpora/stopwords.zip.\n"
          ]
        },
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Temizleme işlemi tamamlandı!\n",
            "\n",
            "--- Makale İçin Ön Analiz ---\n",
            "label\n",
            "ham      71.482487\n",
            "spam    138.670683\n",
            "Name: mesaj_uzunluk, dtype: float64\n"
          ]
        }
      ],
      "source": [
        "import string\n",
        "import nltk\n",
        "from nltk.corpus import stopwords\n",
        "\n",
        "# Gerekli paketleri indiriyoruz\n",
        "nltk.download('stopwords')\n",
        "stop_words = set(stopwords.words('english'))\n",
        "\n",
        "def temizle(metin):\n",
        "    metin = metin.lower() # Hepsini kucuk harfe çevirir.\n",
        "    metin = ''.join([char for char in metin if char not in string.punctuation]) # Noktalama işaretlerini kaldırır.\n",
        "    metin = ''.join([char for char in metin if not char.isdigit()]) # Sayıları kaldırır.\n",
        "    metin = ' '.join([kelime for kelime in metin.split() if kelime not in stop_words]) # Stopwords(the,is,and..)\n",
        "    return metin\n",
        "\n",
        "# Temizlemeden önce orijinal uzunluğu ölçelim\n",
        "df['mesaj_uzunluk'] = df['message'].apply(len)\n",
        "#spam mesajlar genelde daha uzundur.\n",
        "\n",
        "# Temizleme işlemini uygulayalım\n",
        "df['temiz_mesaj'] = df['message'].apply(temizle)\n",
        "\n",
        "print(\"Temizleme işlemi tamamlandı!\")\n",
        "print(\"\\n--- Makale İçin Ön Analiz ---\")\n",
        "# Spam ve Ham mesajların uzunluk farkını görelim\n",
        "print(df.groupby('label')['mesaj_uzunluk'].mean())"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "czu5eHuFjoKn"
      },
      "source": [
        "Metin temizleme aşamasında:\n",
        "- NLTK kütüphanesi (stopwords) kullanılarak, sınıflandırma üzerinde etkisi ve anlamı olmayan ve sık tekrar eden kelimeler veri setinden arındırılmıştır. (the,and,is...)\n",
        "Bu sayede modelin boyutu küçülür ve 'free', 'win', 'call' gibi ayırt edici kelimelerin frekansı (TF-IDF ağırlığı) daha anlamlı hale getirilir.\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "fI0dlul28gC1"
      },
      "source": [
        "# TF-IDF (Kelime Ağırlıgı Hesaplama)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "t8WFoS8t2LYU",
        "outputId": "1e9dbe9b-37c0-472c-ddd8-ea755112a327"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Vektörleştirme Tamamlandı!\n",
            "X (Girdi) Boyutu: (5572, 3000)\n"
          ]
        }
      ],
      "source": [
        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "\n",
        "# TF-IDF nesnesini oluşturuyoruz\n",
        "# max_features=3000: En önemli 3000 kelimeyi alıyoruz(tum kelimeleri alırsak gurultu katabilir,modelin kafası karışabilir)\n",
        "tfidf = TfidfVectorizer(max_features=3000)\n",
        "\n",
        "# Temizlenmiş mesajlarımızı sayılara dönüştürüyoruz(Çunku model sayılardan anlıyor.)\n",
        "X = tfidf.fit_transform(df['temiz_mesaj']).toarray()\n",
        "\n",
        "# Hedef değişkenimizi (spam mi ham mi) sayısallaştırıyoruz\n",
        "# ham = 0, spam = 1\n",
        "y = df['label'].map({'ham': 0, 'spam': 1}).values\n",
        "\n",
        "print(\"Vektörleştirme Tamamlandı!\")\n",
        "print(\"X (Girdi) Boyutu:\", X.shape) # (5572, 3000) gibi bir sonuç gelmeli"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "KUfzMyX8JW8t"
      },
      "source": [
        "TF-IDF ile mesajlarımızdaki kelimeleri sayısal vektöre dönüştürüyoruz modelin anlaması için.\n",
        "-TF (Kelime Sıklığı):Mesajda kelimenin ne kadar gectigine bakar\n",
        "\n",
        "-IDF(Ters Belge Sıklığı):Mesajdaki kelimenin tğm verşsetşndeki oranına bakarak nadirliğine bakar.\n",
        "\n",
        "Sonuc olarak her mesajdaki kelimenin ağırlığı TF*IDF çarpılarak hesaplanır."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "Bmkhc5U76c_7"
      },
      "source": [
        "# Eğitim ve Test Olarak Bölme"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "7RU74HAk6iXS",
        "outputId": "6401e12e-4892-4e98-9fbf-7b5693e63692"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Eğitim seti (X_train) boyutu: (4457, 3000)\n",
            "Test seti (X_test) boyutu: (1115, 3000)\n"
          ]
        }
      ],
      "source": [
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "# Verinin %20'sini test (sınav), %80'ini eğitim için ayırıyoruz\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.20, random_state=42)\n",
        "\n",
        "print(\"Eğitim seti (X_train) boyutu:\", X_train.shape)\n",
        "print(\"Test seti (X_test) boyutu:\", X_test.shape)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "8wdyB-eBW1Jx"
      },
      "source": [
        "# DECİSİON **TREE**"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "Ki4nKoupW3q6",
        "outputId": "4d38e58e-34a0-4318-c24a-7ac30d9f8136"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "--- Karar Ağacı Performans Sonuçları ---\n",
            "Doğruluk (Accuracy) Skoru: %94.53\n",
            "\n",
            "Sınıflandırma Raporu:\n",
            "               precision    recall  f1-score   support\n",
            "\n",
            "           0       0.95      0.99      0.97       966\n",
            "           1       0.94      0.63      0.76       149\n",
            "\n",
            "    accuracy                           0.95      1115\n",
            "   macro avg       0.94      0.81      0.86      1115\n",
            "weighted avg       0.95      0.95      0.94      1115\n",
            "\n"
          ]
        }
      ],
      "source": [
        "from sklearn.tree import DecisionTreeClassifier\n",
        "from sklearn.metrics import accuracy_score, classification_report, confusion_matrix\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Modeli Tanımlama\n",
        "# max_depth=5: Ağacın çok karmaşıklaşmasını ve ezberlemesini önlemek için\n",
        "# maksimum derinliği 5 ile sınırlıyoruz.\n",
        "# random_state=42: Deneyi her çalıştırdığımızda aynı sonuçları almamızı sağlar.\n",
        "dt_model = DecisionTreeClassifier(max_depth=5, random_state=42)\n",
        "\n",
        "# Modeli Eğitme\n",
        "# Model, X_train'deki kelime ağırlıklarına bakarak hangi kelimenin\n",
        "# spama, hangisinin hama çektiğini (kuralları) öğrenir.\n",
        "dt_model.fit(X_train, y_train)\n",
        "\n",
        "# Tahmin Yapma\n",
        "# Test setindeki (X_test) mesajları kendi oluşturduğu Evet/Hayır\n",
        "# sorularından geçirir.\n",
        "y_pred_dt = dt_model.predict(X_test)\n",
        "\n",
        "# Sonuçları Yazdırma\n",
        "print(\"--- Karar Ağacı Performans Sonuçları ---\")\n",
        "# Modelin tahminleri (y_pred_dt) ile gerçek cevapları (y_test) karşılaştırır.\n",
        "print(f\"Doğruluk (Accuracy) Skoru: %{accuracy_score(y_test, y_pred_dt)*100:.2f}\")\n",
        "print(\"\\nSınıflandırma Raporu:\\n\", classification_report(y_test, y_pred_dt))"
      ]
    },
    {
      "cell_type": "markdown",
